@using DataAccessLayer.Models
@model List<Book>

<a class=" btn btn-primary" asp-action="AddBook"> Add Book </a>
<br />
<div>
    <table class="table table-bordered">
        <thead>
            <tr>
                <th> Book ID</th>
                <th> Book Name</th>
                <th> Author</th>
                <th> Book Genre</th>
                <th> Publisher</th>
                <th> Publish Date</th>
                <th>Edit</th>
                <th>Delete</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model)
            {
                <tr>
                    <td>@item.Id</td>
                    <td>@item.Name</td>
                    <td>@item.Author</td>
                    <td>@item.Genre</td>
                    <td>@item.Publisher</td>
                    <td>@item.PublishDate</td>
                    <td><a asp-route-id="@item.Id" asp-action="EditBook" asp-controller="Book" class="btn btn-info">Edit</a></td>
                    <td><a asp-route-id="@item.Id" asp-action="DeleteBook" asp-controller="Book" class="btn btn-danger" onclick="return confirm('Do you really want to delete this record?')">Delete</a></td>
                </tr>
            }
        </tbody>
    </table>
</div>